{
  "name": "@termaite/cli",
  "version": "2.0.0",
  "description": "Rich terminal UI for term.ai.te",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "termaite": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts,tsx --exec \"npm run build\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "ink": "^4.4.1",
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/ws": "^8.5.0",
    "vitest": "^1.0.0",
    "@testing-library/react": "^14.0.0",
    "ink-testing-library": "^3.0.0"
  }
}
